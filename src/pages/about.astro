---
import HeaderComponent from '../components/header.astro';
import Layout from '../layouts/Layout.astro';
import FooterComponent from '../components/footer.astro';
import { Image } from "astro:assets";
import professionalPhoto from "../assets/professional2.png";
import { getCollection, render } from 'astro:content';
import TimelineEntry from '../components/TimelineEntry.astro';
import EducationEntry from '../components/EducationEntry.astro';

const allExperience = await getCollection('experience');
const experienceEntries = allExperience.sort((a, b) => a.data.order - b.data.order);

const allEducation = await getCollection('education');
const educationEntries = allEducation.sort((a, b) => a.data.order - b.data.order);

---

<Layout title="About — Jack Haek">
  <HeaderComponent />

  <main class="about-main">

    <!-- ── Hero: Profile ─────────────────────────────────────── -->
    <section class="profile-section">
      <div class="profile-grid">

        <!-- Photo -->
        <div class="photo-col">
          <div class="photo-glow"></div>
          <div class="photo-frame">
            <Image src={professionalPhoto} alt="Jack Haek" class="portrait"></Image>
            <div class="portrait-desat" aria-hidden="true"></div>
          </div>
        </div>

        <!-- Bio -->
        <div class="bio-col">
          <p class="role-label">Lead LVC Simulation Engineer</p>

          <h1 class="bio-name">JACK HAEK.</h1>

          <div class="bio-body">
            <p>
              Synthesizing physical realities through deterministic modeling and
              cloud-native architectures. I build mission-critical LVC (Live,
              Virtual, Constructive) environments where scalability meets
              sub-millisecond precision.
            </p>
            <p>
              Currently leading simulation-to-flight integration at the
              intersection of aerospace and autonomous systems.
            </p>
          </div>

          <div class="bio-actions">
            <a href="/cv.pdf" class="btn-primary">Download CV</a>
            <a href="mailto:jackjhaek@gmail.com" class="btn-ghost">Get in Touch</a>
          </div>
        </div>

      </div>
    </section>

    <!-- ── Experience Timeline ────────────────────────────────── -->
    <section class="experience-section">
      <div class="section-header section-header--left">
        <h2 class="section-title">EXPERIENCE_LOG</h2>
        <div class="divider-line"></div>
      </div>

      <div class="timeline">
        {experienceEntries.map(async (entry) => {
          const { Content } = await render(entry);
          return (
            <TimelineEntry
              title={entry.data.title}
              company={entry.data.company}
              dateRange={entry.data.dateRange}
              badge={entry.data.badge}
              tags={entry.data.tags}
              accent={entry.data.accent}
            >
              <Content />
            </TimelineEntry>
          );
        })}
      </div>
    </section>

    <!-- ── Technical Stack ────────────────────────────────────── -->
    <section class="stack-section">
      <div class="section-header section-header--right">
        <div class="divider-line"></div>
        <h2 class="section-title">TECHNICAL_STACK</h2>
      </div>

      <div class="skills-grid">

        <!-- Card 1: Key Domains (wide) -->
        <div class="skill-card skill-card--wide skill-card--edu">
          <h3 class="skill-title">Key Domains</h3>
          <p class="skill-desc">
            Designing systems where correctness and performance are
            non-negotiable — across simulation, infrastructure, and
            aerospace domains.
          </p>
          <ul class="feature-grid">
            <li class="feature-item">
              <span class="feature-dot"></span>
              <span>Real-Time Simulation</span>
            </li>
            <li class="feature-item">
              <span class="feature-dot"></span>
              <span>Distributed Systems</span>
            </li>
            <li class="feature-item">
              <span class="feature-dot"></span>
              <span>Cloud-Native Infrastructure</span>
            </li>
            <li class="feature-item">
              <span class="feature-dot"></span>
              <span>Aero / Defense Integration</span>
            </li>
          </ul>
        </div>

        <!-- Card 2: Core Performance — Currently Working With -->
        <div class="skill-card skill-card--perf">
          <h3 class="skill-title">Core Performance</h3>
          <ul class="perf-list">
            <li class="perf-item">
              <span class="perf-label">C++20</span>
              <span class="perf-value">Systems</span>
            </li>
            <li class="perf-item">
              <span class="perf-label">Kubernetes</span>
              <span class="perf-value">Orchestration</span>
            </li>
            <li class="perf-item">
              <span class="perf-label">gRPC / Protobuf</span>
              <span class="perf-value">Comms</span>
            </li>
            <li class="perf-item">
              <span class="perf-label">DPDK / io_uring</span>
              <span class="perf-value">Networking</span>
            </li>
            <li class="perf-item">
              <span class="perf-label">Python</span>
              <span class="perf-value">Data & ML</span>
            </li>
          </ul>
        </div>

        <!-- Card 3: Reliability — Years of Experience by Domain -->
        <div class="skill-card skill-card--rel">
          <h3 class="skill-title">Reliability</h3>
          <ul class="perf-list">
            <li class="perf-item">
              <span class="perf-label">Simulation Systems</span>
              <span class="perf-value">6 yrs</span>
            </li>
            <li class="perf-item">
              <span class="perf-label">Distributed Systems</span>
              <span class="perf-value">5 yrs</span>
            </li>
            <li class="perf-item">
              <span class="perf-label">Cloud-Native / K8s</span>
              <span class="perf-value">4 yrs</span>
            </li>
            <li class="perf-item">
              <span class="perf-label">Real-Time Networking</span>
              <span class="perf-value">3 yrs</span>
            </li>
          </ul>
        </div>

        <!-- Card 4: Education (wide) -->
        <div class="skill-card skill-card--wide-right skill-card--accent-border">
          <h3 class="skill-title">Education</h3>
          <div class="edu-entries">
            {educationEntries.map((entry, i) => (
              <Fragment>
                <EducationEntry
                  institution={entry.data.institution}
                  degree={entry.data.degree}
                  year={entry.data.year}
                  details={entry.data.details}
                />
                {i < educationEntries.length - 1 && <div class="edu-divider"></div>}
              </Fragment>
            ))}
          </div>
        </div>

      </div>
    </section>

  </main>

  <FooterComponent />
</Layout>

<style>
  /* ── Page shell ──────────────────────────────────────────── */
  .about-main {
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 128px;
    padding: 128px var(--space-6) 224px;
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ── Shared section header ───────────────────────────────── */
  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: 64px;
  }

  .section-header--right {
    flex-direction: row-reverse;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--display-sm);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--on-surface);
    white-space: nowrap;
  }

  .divider-line {
    flex: 1;
    height: 1px;
    background: rgba(58, 74, 73, 0.2);
  }

  /* ── Profile section ─────────────────────────────────────── */
  .profile-section {
    padding-top: 80px; /* nav clearance */
  }

  .profile-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--space-8);
    align-items: start;
  }

  /* Photo — cols 1-5 */
  .photo-col {
    grid-column: 1 / span 5;
    position: relative;
  }

  .photo-glow {
    position: absolute;
    inset: -16px;
    background: rgba(0, 247, 247, 0.1);
    border-radius: 12px;
    filter: blur(20px);
    opacity: 0.5;
    pointer-events: none;
  }

  .photo-frame {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-top: 4px solid var(--primary-container);
    border-left: 4px solid var(--primary-container);
    box-shadow: var(--shadow-float);
  }

  .portrait {
    width: 100%;
    height: 150%;
    object-fit: cover;
    object-position: top center;
    margin-top: 0%;
    display: block;
  }

  /* Desaturation overlay (white + saturation blend) */
  .portrait-desat {
    position: absolute;
    inset: 0;
    background: white;
    mix-blend-mode: saturation;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.4s ease;
  }

  .photo-frame:hover .portrait-desat {
    opacity: 0;
  }

  /* Bio — cols 6-12 */
  .bio-col {
    grid-column: 6 / span 7;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-top: var(--space-4);
  }

  .role-label {
    font-family: var(--font-display);
    font-size: var(--label-md);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--primary-container);
  }

  .bio-name {
    font-family: var(--font-display);
    font-size: 6rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
    color: var(--on-surface);
  }

  .bio-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 672px;
  }

  .bio-body p {
    font-family: var(--font-body);
    font-size: 1.5rem;
    font-weight: 400;
    line-height: 2rem;
    color: #b9cac9;
  }

  .bio-actions {
    display: flex;
    gap: var(--space-6);
    align-items: center;
    padding-top: var(--space-8);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 17px 33px;
    background: transparent;
    border: 1px solid rgba(58, 74, 73, 0.3);
    border-radius: var(--radius-md);
    color: var(--primary);
    font-family: var(--font-display);
    font-size: var(--label-md);
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: border-color var(--duration-base) var(--ease-kinetic),
                color var(--duration-base) var(--ease-kinetic);
  }

  .btn-ghost:hover {
    border-color: rgba(0, 221, 221, 0.4);
    color: var(--primary-container);
  }

  /* ── Timeline ────────────────────────────────────────────── */
  .experience-section {
    display: flex;
    flex-direction: column;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-10);
  }

  /* ── Skills bento grid ───────────────────────────────────── */
  .stack-section {
    display: flex;
    flex-direction: column;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 320px 286px;
    gap: var(--space-6);
  }

  .skill-card {
    background: var(--surface-container-low);
    padding: 40px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Column spans */
  .skill-card--wide       { grid-column: 2 / span 2;  grid-row: 2; }
  .skill-card--perf       { grid-column: 3;            grid-row: 1; }
  .skill-card--rel        { grid-column: 1;            grid-row: 2; }
  .skill-card--wide-right { grid-column: 1 / span 2;  grid-row: 1; }

  .skill-card--accent-border {
    border-left: 2px solid var(--primary-container);
  }

  .skill-card--perf {
    background: #1f1f22;
  }

  .skill-card--rel {
    background: var(--surface-container-lowest);
    border: 1px solid rgba(58, 74, 73, 0.1);
  }

  .skill-card--edu {
    background: var(--surface-container-high);
  }

  .edu-entries {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 40px;
    margin-top: auto;
  }

  .skill-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-transform: uppercase;
    color: var(--on-surface);
    line-height: 2rem;
  }

  .skill-desc {
    font-family: var(--font-body);
    font-size: var(--body-lg);
    color: #b9cac9;
    line-height: 24px;
  }

  /* Feature bullet grid (card 1) */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    list-style: none;
    margin-top: auto;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-display);
    font-size: var(--label-sm);
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: var(--on-surface);
  }

  .feature-dot {
    width: 6px;
    height: 6px;
    background: var(--primary-container);
    flex-shrink: 0;
  }

  /* Perf list (card 2) */
  .perf-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: auto;
  }

  .perf-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 9px;
    border-bottom: 1px solid rgba(58, 74, 73, 0.2);
  }

  .perf-label {
    font-family: var(--font-body);
    font-size: var(--label-md);
    color: var(--on-surface);
  }

  .perf-value {
    font-family: var(--font-display);
    font-size: var(--label-sm);
    color: var(--primary-container);
  }

  /* Education (card 4) */
  .edu-divider {
    width: 1px;
    height: 48px;
    background: rgba(58, 74, 73, 0.3);
    flex-shrink: 0;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 960px) {
    .about-main {
      gap: 96px;
      padding-top: 120px;
    }

    .profile-grid {
      grid-template-columns: 1fr;
    }

    .photo-col {
      grid-column: 1;
      max-width: 420px;
    }

    .bio-col {
      grid-column: 1;
    }

    .bio-name {
      font-size: 4rem;
    }

    .bio-body p {
      font-size: 1.25rem;
    }

    .skills-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }

    .skill-card--wide       { grid-column: 1 / -1; grid-row: auto; }
    .skill-card--perf       { grid-column: 1;      grid-row: auto; }
    .skill-card--rel        { grid-column: 2;      grid-row: auto; }
    .skill-card--wide-right { grid-column: 1 / -1; grid-row: auto; }

    .edu-entries {
      flex-direction: column;
    }

    .edu-divider {
      width: 48px;
      height: 1px;
    }
  }

  @media (max-width: 560px) {
    .bio-name {
      font-size: 3rem;
    }

    .bio-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .skills-grid {
      grid-template-columns: 1fr;
    }

    .skill-card--wide,
    .skill-card--perf,
    .skill-card--rel,
    .skill-card--wide-right {
      grid-column: 1;
      grid-row: auto;
    }
  }
</style>
