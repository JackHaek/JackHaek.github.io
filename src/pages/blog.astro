---
import HeaderComponent from '../components/header.astro';
import Layout from '../layouts/Layout.astro';
import FooterComponent from '../components/footer.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const iconSearch = "https://www.figma.com/api/mcp/asset/4f4e548e-8a09-41b9-94df-ef23f6e615f3";

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const total = posts.length;

// Grid placement: alternates big-left/small-right then small-left/big-right
function gridClass(i: number): string {
  if (i === total - 1 && total % 2 === 1) return 'art-solo';
  const pairEven = Math.floor(i / 2) % 2 === 0;
  const isFirst  = i % 2 === 0;
  if (pairEven) return isFirst ? 'art-big-l' : 'art-sm-r';
  else          return isFirst ? 'art-sm-l'  : 'art-big-r';
}

// Card appearance: big-left → overlay, big-right → horizontal split, small → stacked
type CardType = 'featured' | 'wide' | 'regular' | 'solo';
function cardType(i: number): CardType {
  if (i === total - 1 && total % 2 === 1) return 'solo';
  const pairEven = Math.floor(i / 2) % 2 === 0;
  const isFirst  = i % 2 === 0;
  if (pairEven && isFirst)  return 'featured';
  if (!pairEven && !isFirst) return 'wide';
  return 'regular';
}

function formatDate(d: Date): string {
  return d.toISOString().slice(0, 10).replace(/-/g, '.');
}
---

<Layout title="Blog — Jack Haek">
  <HeaderComponent />

  <main class="blog-main">

    <!-- ── Page Header ────────────────────────────────────────── -->
    <div class="page-header">
      <div class="page-header-text" data-reveal>
        <h1 class="page-title">FIELD_NOTES</h1>
        <p class="page-subtitle">
          Weekly notes on things I'm reading, learning at work, or thinking
          through. Mostly M&S, infrastructure, and software engineering.
        </p>
      </div>

      <div class="search-row" data-reveal data-reveal-delay="80">
        <div class="search-wrap">
          <img src={iconSearch} alt="" class="search-icon" width="18" height="18" />
          <input
            type="search"
            class="search-input"
            placeholder="SEARCH"
            aria-label="Search articles"
          />
        </div>

        <div class="filter-chips" role="group" aria-label="Filter by category">
          <button class="filter-chip filter-chip--active" data-chip="all">ALL</button>
          <button class="filter-chip" data-chip="Simulation">SIMULATION</button>
          <button class="filter-chip" data-chip="Infrastructure">INFRASTRUCTURE</button>
          <button class="filter-chip" data-chip="Software">SOFTWARE</button>
        </div>
      </div>
    </div>

    <!-- ── Article Grid ───────────────────────────────────────── -->
    <div class="article-grid">
      {posts.map((post, i) => {
        const slug = post.id.split('/')[0];
        const type = cardType(i);
        const gCls = gridClass(i);
        const date = formatDate(post.data.publishDate);
        return (
          <a href={`/blog/${slug}`} class:list={['art-link', gCls]} data-filter={post.data.filter} data-title={post.data.title.toLowerCase()} data-desc={post.data.description.toLowerCase()}>
            <BlogCard
              type={type}
              title={post.data.title}
              description={post.data.description}
              date={date}
              tags={post.data.tags}
              image={post.data.image}
              imageAlt={post.data.imageAlt}
              slug={slug}
            />
          </a>
        );
      })}
      <div class="art-empty is-hidden" id="art-empty" aria-live="polite">NOTHING_HERE_YET.</div>
    </div>

  </main>

  <FooterComponent />
</Layout>

<script>
  const ART_CLASSES = ['art-big-l','art-sm-r','art-sm-l','art-big-r','art-solo','art-half-l','art-half-r'];
  const FADE_MS    = 200;
  const STAGGER_MS = 45;

  function calcArtClass(i: number, total: number): string {
    if (total === 1) return 'art-solo';
    if (total === 2) return i === 0 ? 'art-half-l' : 'art-half-r';
    if (i === total - 1 && total % 2 === 1) return 'art-solo';
    const pairEven = Math.floor(i / 2) % 2 === 0;
    const isFirst  = i % 2 === 0;
    if (pairEven) return isFirst ? 'art-big-l' : 'art-sm-r';
    return isFirst ? 'art-sm-l' : 'art-big-r';
  }

  let activeFilter = 'all';
  let searchTerm   = '';
  let filtering    = false;

  async function applyBlogFilter() {
    if (filtering) return;
    filtering = true;

    const cards = [...document.querySelectorAll<HTMLElement>('.art-link')];
    const currentlyVisible = cards.filter(c => !c.classList.contains('is-hidden'));

    // Phase 1: fade out all currently visible cards (skip if nothing to fade)
    if (currentlyVisible.length > 0) {
      currentlyVisible.forEach(c => { c.style.opacity = '0'; c.style.transform = 'scale(0.96)'; });
      await new Promise(r => setTimeout(r, FADE_MS));
    }

    // Phase 2: update visibility and recalculate grid placement
    cards.forEach(c => {
      const catOk  = activeFilter === 'all' || c.dataset.filter === activeFilter;
      const srchOk = !searchTerm ||
        (c.dataset.title ?? '').includes(searchTerm) ||
        (c.dataset.desc  ?? '').includes(searchTerm);
      const show = catOk && srchOk;
      if (!show) {
        c.classList.add('is-hidden');
        c.style.opacity = '';
        c.style.transform = '';
      } else {
        c.classList.remove('is-hidden');
      }
    });

    const visible = cards.filter(c => !c.classList.contains('is-hidden'));
    visible.forEach((c, i) => {
      ART_CLASSES.forEach(cls => c.classList.remove(cls));
      c.classList.add(calcArtClass(i, visible.length));
      c.style.opacity = '0';
      c.style.transform = 'translateY(10px) scale(0.97)';
    });

    // Phase 3: stagger fade-in
    visible.forEach((c, i) => {
      setTimeout(() => { c.style.opacity = ''; c.style.transform = ''; }, i * STAGGER_MS);
    });

    // Empty state
    const empty = document.getElementById('art-empty');
    empty?.classList.toggle('is-hidden', visible.length > 0);

    filtering = false;
  }

  function setupBlog() {
    const chips  = document.querySelectorAll<HTMLButtonElement>('[data-chip]');
    const search = document.querySelector<HTMLInputElement>('.search-input');

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('filter-chip--active'));
        chip.classList.add('filter-chip--active');
        activeFilter = chip.dataset.chip!;
        applyBlogFilter();
      });
    });

    search?.addEventListener('input', () => {
      searchTerm = search.value.toLowerCase().trim();
      applyBlogFilter();
    });

    // Run once on load to show empty state if there are no posts
    applyBlogFilter();
  }

  document.addEventListener('astro:page-load', setupBlog);
</script>

<style>
  /* ── Page shell ──────────────────────────────────────────── */
  .blog-main {
    background: var(--surface);
    max-width: 1280px;
    margin: 0 auto;
    padding: 128px var(--space-6) var(--space-20);
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  /* ── Page header ─────────────────────────────────────────── */
  .page-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-top: 80px; /* nav clearance */
  }

  .page-header-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 4.5rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1;
    color: var(--primary);
  }

  .page-subtitle {
    font-family: var(--font-body);
    font-size: var(--title-lg);
    font-weight: 400;
    line-height: 1.625;
    color: var(--text-secondary);
    max-width: 672px;
  }

  /* Search + filters row */
  .search-row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding-top: var(--space-4);
    flex-wrap: wrap;
  }

  .search-wrap {
    position: relative;
    width: 384px;
    flex-shrink: 0;
  }

  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    display: block;
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    background: var(--surface-container-low);
    border: none;
    outline: none;
    padding: var(--space-4) var(--space-6) var(--space-4) 48px;
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--on-surface);
    transition: background var(--duration-base) var(--ease-kinetic);
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-input:focus {
    background: var(--surface-container);
  }

  /* Filter chips */
  .filter-chips {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .filter-chip {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-md);
    border: none;
    background: var(--surface-container-high);
    color: var(--text-secondary);
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--duration-base) var(--ease-kinetic),
                color var(--duration-base) var(--ease-kinetic);
  }

  .filter-chip--active {
    background: var(--primary-container);
    color: var(--on-primary-container);
  }

  .filter-chip:not(.filter-chip--active):hover {
    background: var(--surface-container-highest);
    color: var(--on-surface);
  }

  /* ── Article grid ────────────────────────────────────────── */
  .article-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: var(--space-6);
  }

  /* Link wrapper */
  .art-link {
    display: flex;
    flex-direction: column;
    text-decoration: none;
  }

  .art-link .art {
    flex: 1;
    transition: opacity var(--duration-base) var(--ease-kinetic);
  }

  .art-link:hover .art {
    opacity: 0.85;
  }

  /* Grid placement */
  .art-big-l { grid-column: 1 / span 8; }
  .art-sm-r  { grid-column: 9 / span 4; }
  .art-sm-l  { grid-column: 1 / span 4; }
  .art-big-r { grid-column: 5 / span 8; }
  .art-solo  { grid-column: 1 / -1; }

  .is-hidden { display: none; }

  /* ── Card animation ──────────────────────────────────────── */
  .art-link {
    transition: opacity 0.2s ease, transform 0.25s ease;
  }

  /* 2-item equal-halves layout */
  .art-half-l { grid-column: 1 / span 6; }
  .art-half-r { grid-column: 7 / span 6; }

  /* Empty state */
  .art-empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 80px var(--space-6);
    font-family: var(--font-display);
    font-size: var(--display-sm);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text-secondary);
    opacity: 0.4;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 1100px) {
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .art-big-l,
    .art-sm-r,
    .art-solo  { grid-column: 1 / -1; }
    .art-sm-l  { grid-column: 1; }
    .art-big-r { grid-column: 2; }

  }

  @media (max-width: 720px) {
    .blog-main {
      padding-top: 100px;
    }

    .page-title {
      font-size: 3rem;
    }

    .search-wrap {
      width: 100%;
    }

    .article-grid {
      grid-template-columns: 1fr;
    }

    .art-big-l,
    .art-sm-r,
    .art-sm-l,
    .art-big-r,
    .art-solo  { grid-column: 1; }

  }
</style>
