---
---

<dialog id="contact-modal" class="contact-modal">
  <div class="modal-inner">
    <div class="modal-header">
      <h2 class="modal-title">GET_IN_TOUCH</h2>
      <button id="modal-close" class="modal-close" aria-label="Close">&times;</button>
    </div>
    <form id="contact-form" novalidate>
      <div class="form-field">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" placeholder="Your name" required />
      </div>
      <div class="form-field">
        <label for="from_email">Email</label>
        <input type="email" id="from_email" name="from_email" placeholder="your@email.com" required />
      </div>
      <div class="form-field">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" placeholder="What's on your mind?" required></textarea>
      </div>
      <div class="form-footer">
        <p id="form-status" class="form-status" aria-live="polite"></p>
        <button type="submit" id="submit-btn" class="btn-primary">Send Message</button>
      </div>
    </form>
  </div>
</dialog>

<script>
  import emailjs from '@emailjs/browser';

  //Checked documentation - Safe to expose all 3 of these values
  const SERVICE_ID  = 'service_rn14ox3';
  const TEMPLATE_ID = 'template_gfv61e8';
  const PUBLIC_KEY  = 'kDQwLKXKP8NOpbkZM';

  emailjs.init(PUBLIC_KEY);

  function setup() {
    const modal     = document.getElementById('contact-modal') as HTMLDialogElement | null;
    const closeBtn  = document.getElementById('modal-close');
    const form      = document.getElementById('contact-form') as HTMLFormElement | null;
    const status    = document.getElementById('form-status');
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

    if (!modal || !closeBtn || !form || !status || !submitBtn) return;

    // Bind all trigger elements on the page
    document.querySelectorAll<HTMLElement>('[data-open-contact]').forEach(el =>
      el.addEventListener('click', () => modal.showModal())
    );

    closeBtn.addEventListener('click', () => modal.close());

    // Close when clicking the backdrop
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    // Reset status when modal re-opens
    modal.addEventListener('show', () => {
      status.textContent = '';
      status.className = 'form-status';
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
      status.textContent = '';

      try {
        await emailjs.sendForm(SERVICE_ID, TEMPLATE_ID, form);
        status.textContent = 'Message sent — I\'ll get back to you soon.';
        status.className = 'form-status form-status--ok';
        form.reset();
      } catch {
        status.textContent = 'Something went wrong. Please try again.';
        status.className = 'form-status form-status--err';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message';
      }
    });
  }

  document.addEventListener('astro:page-load', setup);
</script>

<style is:global>
  .contact-modal {
    background: var(--surface-container-low);
    border: 1px solid var(--surface-container-high);
    border-radius: var(--radius-lg);
    padding: 0;
    width: min(560px, 92vw);
    max-height: 90dvh;
    overflow-y: auto;
    box-shadow: var(--shadow-float);
    margin: auto;
  }

  .contact-modal::backdrop {
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .modal-inner {
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .modal-title {
    font-family: var(--font-display);
    font-size: var(--display-sm);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--on-surface);
  }

  .modal-close {
    background: none;
    border: none;
    color: var(--text-secondary);
    font-size: 1.75rem;
    line-height: 1;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: var(--radius-sm);
    transition: color var(--duration-base) var(--ease-kinetic);
  }

  .modal-close:hover {
    color: var(--on-surface);
  }

  #contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-field label {
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .form-field input,
  .form-field textarea {
    background: var(--surface-container-lowest);
    border: 1px solid var(--surface-container-high);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: var(--body-md);
    color: var(--on-surface);
    width: 100%;
    box-sizing: border-box;
    transition: border-color var(--duration-base) var(--ease-kinetic);
    resize: vertical;
  }

  .form-field input::placeholder,
  .form-field textarea::placeholder {
    color: var(--text-secondary);
    opacity: 0.6;
  }

  .form-field input:focus,
  .form-field textarea:focus {
    outline: none;
    border-color: var(--primary-container);
  }

  .form-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .form-status {
    font-family: var(--font-body);
    font-size: var(--body-sm);
    color: var(--text-secondary);
  }

  .form-status--ok  { color: var(--primary-container); }
  .form-status--err { color: #f28b82; }
</style>
