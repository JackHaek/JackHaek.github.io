<style>
  .site-footer {
    background: var(--surface-container-low);
    padding: var(--space-10) var(--space-6);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-copy {
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #64748b;
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
  }

  .footer-link {
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #64748b;
    transition: color var(--duration-base) var(--ease-kinetic);
  }

  .footer-link:hover {
    color: var(--on-surface-variant);
  }

  @media (max-width: 600px) {
    .footer-inner {
      flex-direction: column;
      gap: var(--space-6);
      text-align: center;
    }
  }
