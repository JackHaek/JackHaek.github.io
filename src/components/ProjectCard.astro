---
interface Props {
  // Content
  title: string;
  category: string;
  image?: string;
  imageAlt?: string;
  description?: string;
  tags?: string[];

  // Layout
  layout?: 'overlay' | 'gallery' | 'research';
  titleSize?: 'sm' | 'md' | 'lg' | 'xl';

  // Gallery-specific
  imageHeight?: string;           // CSS height value for the image wrapper, e.g. '450px'
  imageCrop?: 'default' | 'wide' | 'tall';
  gradientOpacity?: number;       // 0–1, defaults to 0.8
  featured?: boolean;             // overlays badge + title inside image
  featuredLabel?: string;

  // Research-specific
  cta?: string;

  // Shared view transition name (slug). Enables morph from listing → detail page.
  transitionName?: string;

  // Grid placement passthrough
  class?: string;
}

const {
  title,
  category,
  image,
  imageAlt = '',
  description,
  tags,
  layout = 'overlay',
  titleSize = 'lg',
  imageHeight,
  imageCrop = 'default',
  gradientOpacity = 0.8,
  featured = false,
  featuredLabel = 'Featured Case Study',
  transitionName,
  cta,
  class: className,
} = Astro.props;
---

{layout === 'overlay' && (
  <div class:list={['project-card', 'project-card--overlay', className]}>
    {image && <img src={image} alt={imageAlt} class="overlay-img" />}
    <div class="overlay-content">
      <span class="card-category">{category}</span>
      <h3 class:list={['card-title', `card-title--${titleSize}`]}>{title}</h3>
    </div>
  </div>
)}

{layout === 'gallery' && (
  <div class:list={['project-card', 'project-card--gallery', className]}>
    <div
      class="gallery-img-wrap"
      style={imageHeight ? `height:${imageHeight}` : undefined}
      transition:name={transitionName ? `${transitionName}-img` : undefined}
    >
      {image && (
        <>
          <img
            src={image}
            alt={imageAlt}
            class:list={['gallery-img', `gallery-img--${imageCrop}`]}
          />
          <div class="gallery-desat" aria-hidden="true"></div>
          <div class="gallery-gradient" style={`opacity:${gradientOpacity}`}></div>
        </>
      )}
      {featured && (
        <div class="gallery-caption">
          <span class="featured-badge">{featuredLabel}</span>
          <h2 class:list={['card-title', 'card-title--white', `card-title--${titleSize}`]}>
            {title}
          </h2>
        </div>
      )}
    </div>
    <div class="gallery-body">
      {!featured && (
        <h2
          class:list={['card-title', 'card-title--white', `card-title--${titleSize}`]}
          transition:name={transitionName ? `${transitionName}-title` : undefined}
        >
          {title}
        </h2>
      )}
      {description && <p class="card-desc">{description}</p>}
      {tags && tags.length > 0 && (
        <ul class="chip-list">
          {tags.map((tag) => <li class="chip">{tag}</li>)}
        </ul>
      )}
    </div>
  </div>
)}

{layout === 'research' && (
  <div class:list={['project-card', 'project-card--research', className]}>
    <div class="research-bg"></div>
    <div class="research-content">
      <span class="card-category">{category}</span>
      <h3 class="research-title" set:html={title}></h3>
      {cta && <button class="btn-research">{cta}</button>}
    </div>
  </div>
)}

<style>
  /* ── Base ────────────────────────────────────────────────── */
  .project-card {
    position: relative;
    overflow: hidden;
    background: var(--surface-container-low);
    border-radius: var(--radius-lg);
    box-shadow: var(--card-shadow);
  }

  /* ── Shared typography ───────────────────────────────────── */
  .card-category {
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--primary-container);
  }

  .card-title {
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--on-surface);
    line-height: 1.2;
    letter-spacing: -0.025em;
    text-transform: uppercase;
  }

  .card-title--white { color: white; }

  .card-title--sm  { font-size: var(--headline-md); }
  .card-title--md  { font-size: 1.25rem; }
  .card-title--lg  { font-size: var(--display-sm); }
  .card-title--xl  { font-size: 1.875rem; }

  .card-desc {
    font-family: var(--font-body);
    font-size: var(--body-md);
    font-weight: 300;
    line-height: 20px;
    color: var(--text-secondary);
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-2);
    list-style: none;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    padding: var(--space-1) var(--space-3);
    background: var(--surface-container-high);
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
  }

  /* ── Overlay layout (home page) ──────────────────────────── */
  .project-card--overlay {
    /* Height is set by the parent grid row */
  }

  .overlay-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.4;
  }

  .overlay-content {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--img-gradient-stop) 0%, transparent 60%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 40px;
    gap: var(--space-2);
  }

  /* ── Gallery layout (projects page) ─────────────────────── */
  .project-card--gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .gallery-img-wrap {
    position: relative;
    overflow: hidden;
    background: var(--surface-container-low);
    flex-shrink: 0;
  }

  .gallery-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 178%;
    object-fit: cover;
    object-position: center;
    top: -39%;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .gallery-img--wide {
    height: 100%;
    width: 125%;
    left: -12.5%;
    top: 0;
  }

  .gallery-img--tall {
    height: 233%;
    top: -67%;
  }

  .gallery-desat {
    position: absolute;
    inset: 0;
    background: white;
    mix-blend-mode: saturation;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .gallery-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, var(--img-gradient-stop) 0%, transparent 100%);
    pointer-events: none;
  }

  .gallery-caption {
    position: absolute;
    bottom: var(--space-6);
    left: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .featured-badge {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: var(--space-1) var(--space-3);
    background: rgba(0, 55, 55, 0.2);
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--primary-fixed-dim);
  }

  .project-card--gallery:hover .gallery-img {
    transform: scale(1.05);
  }

  .project-card--gallery:hover .gallery-desat {
    opacity: 0;
  }

  .gallery-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: 0 var(--space-2);
  }

  /* ── Research layout (home page) ─────────────────────────── */
  .research-bg {
    position: absolute;
    inset: 0;
    opacity: 0.2;
    background:
      radial-gradient(ellipse at 50% 50%, rgba(58, 74, 73, 1) 0%, rgba(58, 74, 73, 0) 70%),
      linear-gradient(90deg, rgba(0, 221, 221, 0.05), rgba(0, 221, 221, 0.05));
  }

  .research-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 40px;
    gap: var(--space-6);
    text-align: center;
  }

  .research-title {
    font-family: var(--font-display);
    font-size: var(--display-sm);
    font-weight: 700;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: var(--on-surface);
    line-height: 1.1;
    max-width: 512px;
  }

  .btn-research {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 13px 25px;
    background: transparent;
    border: 1px solid var(--primary-container);
    color: var(--primary-container);
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background var(--duration-base) var(--ease-kinetic);
  }

  .btn-research:hover {
    background: rgba(0, 247, 247, 0.1);
  }

  /* ── Light mode overrides ────────────────────────────────── */
  :global([data-theme="light"]) .gallery-desat {
    opacity: 0;
  }

  :global([data-theme="light"]) .overlay-img {
    opacity: 0.7;
  }
</style>
