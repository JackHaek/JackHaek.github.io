---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    category: 'Hybrid Architecture',
    title: 'LVC_SYNCHRONIZER_V1',
    image: 'https://www.figma.com/api/mcp/asset/c58a4af4-f41c-4758-ad83-9dd2047980de',
    imageAlt: 'LVC Interface',
    titleSize: 'lg' as const,
    gridClass: 'card-large',
  },
  {
    category: 'Systems Integration',
    title: 'HARDWARE_IN_THE_LOOP',
    image: 'https://www.figma.com/api/mcp/asset/752b765d-627e-4ab4-bb46-f05fd9f10329',
    imageAlt: 'HIL Testing',
    titleSize: 'sm' as const,
    gridClass: 'card-small-tr',
  },
  {
    category: 'Infrastructure',
    title: 'K8S_LVC_SCALING',
    image: 'https://www.figma.com/api/mcp/asset/7ef11853-e7e3-4bd7-96ae-e83f71b2c725',
    imageAlt: 'Distributed Systems',
    titleSize: 'sm' as const,
    gridClass: 'card-small-bl',
  },
];
---

<section class="mission-reports" id="projects">
  <div class="mission-inner">

    <div class="section-header">
      <h2 class="section-title">MISSION_REPORTS</h2>
      <div class="section-divider"></div>
    </div>

    <div class="bento-grid">

      {projects.map((p) => (
        <ProjectCard
          category={p.category}
          title={p.title}
          image={p.image}
          imageAlt={p.imageAlt}
          titleSize={p.titleSize}
          class={p.gridClass}
        />
      ))}

      <ProjectCard
        variant="research"
        category="Proprietary Research"
        title={"Deterministic Real-Time<br />Networking for Swarm Sim"}
        cta="Request Whitepaper"
        class="card-wide"
      />

    </div>
  </div>
</section>

<style>
  .mission-reports {
    background: var(--surface);
    padding: var(--space-20) var(--space-6);
  }

  .mission-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--display-sm);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--on-surface);
  }

  .section-divider {
    width: 96px;
    height: 1px;
    background: var(--primary-container);
  }

  /* Bento grid — layout only, card visuals live in ProjectCard */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 400px 400px;
    gap: var(--space-6);
  }

  :global(.card-large)    { grid-column: 1 / span 2; grid-row: 1; }
  :global(.card-small-tr) { grid-column: 3;           grid-row: 1; }
  :global(.card-small-bl) { grid-column: 1;           grid-row: 2; }
  :global(.card-wide)     { grid-column: 2 / span 2;  grid-row: 2; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 300px 300px 300px;
    }

    :global(.card-large)    { grid-column: 1 / -1; grid-row: 1; }
    :global(.card-small-tr) { grid-column: 1;      grid-row: 2; }
    :global(.card-small-bl) { grid-column: 2;      grid-row: 2; }
    :global(.card-wide)     { grid-column: 1 / -1; grid-row: 3; }
  }

  @media (max-width: 560px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(4, 280px);
    }

    :global(.card-large)    { grid-column: 1; grid-row: 1; }
    :global(.card-small-tr) { grid-column: 1; grid-row: 2; }
    :global(.card-small-bl) { grid-column: 1; grid-row: 3; }
    :global(.card-wide)     { grid-column: 1; grid-row: 4; }
  }
</style>
