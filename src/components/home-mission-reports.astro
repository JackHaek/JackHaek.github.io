---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const allProjects = await getCollection('projects', ({ data }) => data.featured);
const projects = allProjects
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);

const gridClasses = ['card-large', 'card-small-tr', 'card-small-bl'] as const;
const titleSizes = ['lg', 'sm', 'sm'] as const;
---

<section class="mission-reports" id="projects">
  <div class="mission-inner">

    <div class="section-header">
      <h2 class="section-title">MISSION_REPORTS</h2>
      <div class="section-divider"></div>
    </div>

    <div class="bento-grid">

      {projects.map((entry, i) => (
        <a
          href={`/projects/${entry.id.split('/')[0]}`}
          class:list={['card-link', gridClasses[i]]}
          aria-label={`View project: ${entry.data.title}`}
        >
          <ProjectCard
            category={entry.data.category}
            title={entry.data.title}
            image={entry.data.image?.src}
            imageAlt={entry.data.imageAlt}
            titleSize={titleSizes[i]}
          />
          <span class="card-cta" aria-hidden="true">VIEW_MISSION →</span>
        </a>
      ))}

      <ProjectCard
        variant="research"
        category="Proprietary Research"
        title={"Deterministic Real-Time<br />Networking for Swarm Sim"}
        cta="Request Whitepaper"
        class="card-wide"
      />

    </div>
  </div>
</section>

<style>
  .mission-reports {
    background: var(--surface);
    padding: var(--space-20) var(--space-6);
  }

  .mission-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 80px;
  }

  .section-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--display-sm);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.1;
    color: var(--on-surface);
  }

  .section-divider {
    width: 96px;
    height: 1px;
    background: var(--primary-container);
  }

  /* ── Card link wrapper ───────────────────────────────────── */
  .card-link {
    display: block;
    position: relative;
    text-decoration: none;
    cursor: pointer;
  }

  /* Card fills the anchor */
  .card-link :global(.project-card) {
    height: 100%;
    transition: box-shadow 0.35s var(--ease-kinetic);
  }

  /* Inset border appears on hover */
  .card-link:hover :global(.project-card) {
    box-shadow: inset 0 0 0 1px var(--primary-container);
  }

  /* Image slowly zooms in */
  .card-link :global(.overlay-img) {
    transition: transform 0.55s var(--ease-kinetic), opacity 0.4s var(--ease-kinetic);
  }

  .card-link:hover :global(.overlay-img) {
    transform: scale(1.04);
    opacity: 0.55;
  }

  /* CTA label — slides up and fades in */
  .card-cta {
    position: absolute;
    top: var(--space-6);
    right: var(--space-6);
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--primary-container);
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.3s var(--ease-kinetic), transform 0.3s var(--ease-kinetic);
    pointer-events: none;
  }

  .card-link:hover .card-cta {
    opacity: 1;
    transform: translateY(0);
  }

  /* Bento grid — layout only, card visuals live in ProjectCard */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 400px 400px;
    gap: var(--space-6);
  }

  :global(.card-large)    { grid-column: 1 / span 2; grid-row: 1; }
  :global(.card-small-tr) { grid-column: 3;           grid-row: 1; }
  :global(.card-small-bl) { grid-column: 1;           grid-row: 2; }
  :global(.card-wide)     { grid-column: 2 / span 2;  grid-row: 2; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .bento-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 300px 300px 300px;
    }

    :global(.card-large)    { grid-column: 1 / -1; grid-row: 1; }
    :global(.card-small-tr) { grid-column: 1;      grid-row: 2; }
    :global(.card-small-bl) { grid-column: 2;      grid-row: 2; }
    :global(.card-wide)     { grid-column: 1 / -1; grid-row: 3; }
  }

  @media (max-width: 560px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(4, 280px);
    }

    :global(.card-large)    { grid-column: 1; grid-row: 1; }
    :global(.card-small-tr) { grid-column: 1; grid-row: 2; }
    :global(.card-small-bl) { grid-column: 1; grid-row: 3; }
    :global(.card-wide)     { grid-column: 1; grid-row: 4; }
  }
</style>
