---
interface Props {
  institution: string;
  degree:      string;
  year:        string;
  details?:    string[];
}

const { institution, degree, year, details } = Astro.props;
---

<div class="edu-entry">
  <p class="edu-degree">{degree}</p>
  <p class="edu-school"><strong>{institution}</strong> — {year}</p>
  {details?.map(d => <p class="edu-detail">{d}</p>)}
</div>

<style>
  .edu-entry {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .edu-degree {
    font-family: var(--font-display);
    font-size: var(--title-lg);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--on-surface);
    line-height: 1.3;
  }

  .edu-school {
    font-family: var(--font-body);
    font-size: var(--body-lg);
    color: var(--text-secondary);
    line-height: 24px;
  }

  .edu-school strong {
    color: var(--on-surface);
    font-weight: 400;
  }

  .edu-detail {
    font-family: var(--font-body);
    font-size: var(--body-md);
    color: var(--text-muted);
    line-height: 20px;
  }
</style>
