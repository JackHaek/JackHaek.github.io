---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const logoModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/logos/*.png',
  { eager: true }
);

const logos = Object.entries(logoModules).map(([path, mod]) => ({
  img: mod.default,
  alt: path.split('/').pop()!.replace('.png', ''),
}));
---

<section class="logo-scroll">
  <div class="logo-viewport" id="logo-viewport">
    <div class="logo-track" id="logo-track">
      {logos.map(({ img, alt }) => (
        <div class="logo-item">
          <Image src={img} alt={alt} height={72} draggable="false" />
        </div>
      ))}
      {logos.map(({ img, alt }) => (
        <div class="logo-item" aria-hidden="true">
          <Image src={img} alt="" height={72} draggable="false" />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .logo-scroll {
    background: var(--surface-container-lowest);
    padding: var(--space-12) 0;
  }

  .logo-viewport {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
  }

  .logo-track {
    display: flex;
    align-items: center;
    gap: 80px;
    padding: 0 40px;
    width: max-content;
    will-change: transform;
  }

  .logo-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-item img {
    height: 72px;
    width: auto;
    user-select: none;
    pointer-events: none;
    filter: grayscale(1) brightness(0.3);
    opacity: 0.55;
    transition: filter 0.4s ease, opacity 0.4s ease;
  }

  .logo-item.logo--active img {
    filter: none;
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-item img {
      filter: none;
      opacity: 0.8;
    }
  }
</style>

<script>
  const SPEED         = 1.2;  // max px per frame
  const PAUSE_FRAMES  = 55;   // ~0.9 s at 60 fps
  const CENTER_ZONE   = 55;   // px — trigger colour
  const PAUSE_ZONE    = 28;   // px — trigger stop
  const SLOWDOWN_ZONE = 140;  // px — begin decelerating
  const EASE          = 0.07; // lerp factor (higher = snappier)

  let rafId: number | null = null;

  function initLogoScroll() {
    // Cancel any existing loop before re-initializing (View Transitions safety)
    if (rafId !== null) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }

    const viewport = document.getElementById('logo-viewport');
    const track    = document.getElementById('logo-track');
    if (!viewport || !track) return;

    const items = [...track.querySelectorAll<HTMLElement>('.logo-item')];

    // Cache each item's centre X within the track — static, computed once
    const centers = items.map(el => ({
      el,
      cx: el.offsetLeft + el.offsetWidth / 2,
    }));

    let pos          = 0;
    let currentSpeed = 0;
    let targetSpeed  = SPEED;
    let countdown    = 0;
    const paused     = new WeakSet<HTMLElement>();

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function tick(): void {
      const vpCx    = viewport.offsetWidth / 2;
      const halfLen = track.scrollWidth / 2;

      // Find the item whose centre is closest to the viewport centre
      let minDist = Infinity;
      let closest: HTMLElement | null = null;

      for (const { el, cx } of centers) {
        const dist = Math.abs(cx - pos - vpCx);
        if (dist < minDist) { minDist = dist; closest = el; }
      }

      // Apply colour to only the closest item when it's within the zone
      for (const { el } of centers) {
        el.classList.toggle(
          'logo--active',
          !reduced && el === closest && minDist < CENTER_ZONE
        );
      }

      if (countdown > 0) {
        // Pause: hold position, keep speed at zero
        countdown--;
        currentSpeed = 0;
      } else {
        // Trigger a fresh pause when the closest item reaches the inner zone
        if (!reduced && closest && minDist < PAUSE_ZONE && !paused.has(closest)) {
          paused.add(closest);
          countdown    = PAUSE_FRAMES;
          currentSpeed = 0;
        } else {
          // Decelerate smoothly as an un-paused logo approaches centre,
          // then accelerate freely once it has been paused (in the WeakSet)
          if (!reduced && closest && minDist < SLOWDOWN_ZONE && !paused.has(closest)) {
            const t = minDist / SLOWDOWN_ZONE;
            targetSpeed = SPEED * t * t * (3 - 2 * t); // smoothstep 0 → SPEED
          } else {
            targetSpeed = SPEED;
          }

          // Lerp toward target — provides ease-out after pause and smooths
          // any abrupt speed changes
          currentSpeed += (targetSpeed - currentSpeed) * EASE;
        }

        pos += currentSpeed;
        if (pos >= halfLen) pos -= halfLen;
        track.style.transform = `translateX(${-pos}px)`;
      }

      // Release the paused flag once the item is well past the centre zone
      for (const { el, cx } of centers) {
        if (Math.abs(cx - pos - vpCx) > CENTER_ZONE * 3) paused.delete(el);
      }

      rafId = requestAnimationFrame(tick);
    }

    rafId = requestAnimationFrame(tick);
  }

  // Cancel the loop when navigating away so it doesn't run against a detached DOM
  document.addEventListener('astro:before-swap', () => {
    if (rafId !== null) {
      cancelAnimationFrame(rafId);
      rafId = null;
    }
  });

  document.addEventListener('astro:page-load', initLogoScroll);
</script>
