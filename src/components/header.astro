---
import { Image } from 'astro:assets';
import moon from '../assets/moon.svg';
import sun from '../assets/sun.svg';
---

<header class="nav-glass">
  <div class="nav-inner">

    <a href="/" class="nav-brand" aria-label="Home">
      JACK_HAEK
    </a>

    <nav aria-label="Primary navigation">
      <ul class="nav-links">
        <li><a href="/" class="nav-link">Home</a></li>
        <li><a href="/projects" class="nav-link">Projects</a></li>
        <li><a href="/about" class="nav-link">About</a></li>
        <li><a href="/blog" class="nav-link">Blog</a></li>
      </ul>
    </nav>

    <button class="theme-toggle" aria-label="Toggle light/dark mode" id="theme-toggle">
      <span class="toggle-icon toggle-icon--moon">
        <Image src={moon} alt="" width={18} height={18} />
      </span>
      <span class="toggle-icon toggle-icon--sun">
        <Image src={sun} alt="" width={18} height={18} />
      </span>
    </button>

  </div>
</header>

<script>
  function setupToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.onclick = () => {
      const isLight = document.documentElement.dataset.theme === 'light';
      if (isLight) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
      } else {
        document.documentElement.dataset.theme = 'light';
        localStorage.setItem('theme', 'light');
      }
    };
  }

  setupToggle();
  document.addEventListener('astro:after-swap', setupToggle);
</script>

<style>
  /* ── Glassmorphic nav shell ──────────────────────────────── */
  .nav-glass {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--glass-bg);
    backdrop-filter: var(--glass-blur);
    -webkit-backdrop-filter: var(--glass-blur);
    /* No border — use background shift for separation per "No-Line" rule */
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    max-width: 1280px;
    margin: 0 auto;
    padding: var(--space-4) var(--space-6);
  }

  /* ── Brand ───────────────────────────────────────────────── */
  .nav-brand {
    font-family: var(--font-display);
    font-size: var(--label-lg);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--primary-fixed-dim);
    white-space: nowrap;
    transition: color var(--duration-base) var(--ease-kinetic);
  }

  .nav-brand:hover {
    color: var(--primary-container);
  }

  /* ── Nav links ───────────────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: var(--label-md);
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    position: relative;
    padding-bottom: 2px;
    transition: color var(--duration-base) var(--ease-kinetic);
  }

  /* Underline that expands from center on hover */
  .nav-link::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    width: 0;
    height: 1px;
    background: var(--primary-fixed-dim);
    transform: translateX(-50%);
    transition: width var(--duration-base) var(--ease-kinetic);
  }

  .nav-link:hover {
    color: var(--on-surface);
  }

  .nav-link:hover::after,
  .nav-link[aria-current="page"]::after {
    width: 100%;
  }

  .nav-link[aria-current="page"] {
    color: var(--primary-fixed-dim);
  }

  /* ── Theme toggle — glassmorphic pill ────────────────────── */
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--surface-container-high);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    flex-shrink: 0;
    transition: background var(--duration-base) var(--ease-kinetic),
                transform var(--duration-base) var(--ease-kinetic);
  }

  .theme-toggle:hover {
    background: var(--surface-container-highest);
    transform: scale(1.08);
  }

  .toggle-icon {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Show moon in dark mode, sun in light mode */
  .toggle-icon--sun  { display: none; }
  .toggle-icon--moon { display: flex; }

  :global([data-theme="light"]) .toggle-icon--moon { display: none; }
  :global([data-theme="light"]) .toggle-icon--sun  { display: flex; }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 640px) {
    .nav-brand {
      font-size: var(--label-md);
    }

    .nav-links {
      gap: var(--space-5);
    }
  }

  @media (max-width: 480px) {
    .nav-inner {
      padding: var(--space-3) var(--space-4);
    }
  }
</style>