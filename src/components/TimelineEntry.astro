---
interface Props {
  title:     string;
  company:   string;
  dateRange: string;
  badge?:    string;
  tags:      string[];
  accent?:   boolean;
}

const { title, company, dateRange, badge, tags, accent = false } = Astro.props;
---

<div class="timeline-row">
  <div class="timeline-meta">
    <span class="timeline-date">{dateRange}</span>
    {badge && <span class="timeline-badge">{badge}</span>}
  </div>
  <div class:list={['timeline-card', accent && 'timeline-card--accent']}>
    {accent && <div class="card-glow"></div>}
    <h3 class="timeline-title">{title}</h3>
    <p class="timeline-company">{company}</p>
    <div class="timeline-desc"><slot /></div>
    <ul class="chip-list">
      {tags.map(tag => <li class="chip">{tag}</li>)}
    </ul>
  </div>
</div>

<style>
  .timeline-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .timeline-meta {
    grid-column: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: 17px;
  }

  .timeline-date {
    font-family: var(--font-display);
    font-size: var(--label-md);
    font-weight: 400;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .timeline-badge {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 3px 9px;
    background: rgba(0, 247, 247, 0.2);
    border: 1px solid rgba(0, 247, 247, 0.3);
    border-radius: 2px;
    font-family: var(--font-body);
    font-size: var(--label-sm);
    font-weight: 600;
    letter-spacing: -0.05em;
    text-transform: uppercase;
    color: var(--primary-container);
  }

  .timeline-card {
    grid-column: 2 / span 3;
    background: var(--surface-container-low);
    border-radius: 4px;
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    position: relative;
    overflow: hidden;
  }

  .timeline-card--accent {
    border-left: 4px solid var(--primary-container);
    padding-left: 44px;
  }

  .card-glow {
    position: absolute;
    top: -64px;
    right: -64px;
    width: 128px;
    height: 128px;
    background: rgba(0, 247, 247, 0.05);
    border-radius: 12px;
    pointer-events: none;
  }

  .timeline-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    text-transform: uppercase;
    color: var(--on-surface);
    line-height: 2rem;
  }

  .timeline-company {
    font-family: var(--font-display);
    font-size: var(--label-md);
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--primary-container);
  }

  .timeline-desc :global(p) {
    font-family: var(--font-body);
    font-size: var(--body-lg);
    font-weight: 400;
    line-height: 26px;
    color: var(--text-secondary);
    padding-top: var(--space-4);
    margin: 0;
  }

  .chip-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-4);
    list-style: none;
  }

  .chip {
    font-family: var(--font-display);
    font-size: var(--label-sm);
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--on-surface-variant);
    background: var(--surface-container-high);
    padding: 4px 12px;
  }

  /* ── Responsive ── */
  @media (max-width: 960px) {
    .timeline-row {
      grid-template-columns: 1fr;
    }

    .timeline-meta {
      grid-column: 1;
      flex-direction: row;
      align-items: center;
      gap: var(--space-4);
      padding-top: 0;
    }

    .timeline-card {
      grid-column: 1;
    }
  }
</style>
