---
import '@/styles/global.css';
import 'katex/dist/katex.min.css';
import { ClientRouter } from 'astro:transitions';
import { getImage } from 'astro:assets';
import professionalPhoto from '@/assets/professional2.png';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Modeling and Simulation Engineer — portfolio, projects, and field notes.',
  ogImage,
} = Astro.props;

const defaultOgImg = await getImage({
  src: professionalPhoto,
  width: 1200,
  height: 630,
  format: 'jpeg',
  fit: 'cover',
  position: 'top',
});

// Use request origin so the URL is correct in dev (localhost), preview, and production
const origin = Astro.url.origin;
const ogImageUrl = new URL(ogImage ?? defaultOgImg.src, origin).href;
const canonicalUrl = new URL(Astro.url.pathname, origin).href;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Fonts preconnect for performance -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:site_name" content="Jack Haek" />

		<!-- Twitter / Discord -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />

		<ClientRouter />
		<script is:inline>
		  const t = localStorage.getItem('theme');
		  if (t === 'light') document.documentElement.dataset.theme = 'light';

		  if (!window.__themeSwapReady) {
		    window.__themeSwapReady = true;
		    document.addEventListener('astro:before-swap', function(e) {
		      const theme = document.documentElement.getAttribute('data-theme');
		      if (theme) e.newDocument.documentElement.setAttribute('data-theme', theme);
		      else e.newDocument.documentElement.removeAttribute('data-theme');
		    });
		  }
		</script>
	</head>
	<body transition:animate="fade">
		<slot />
	</body>
</html>

<script>
  function initReveal() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        el.style.transitionDelay = `${el.dataset.revealDelay ?? 0}ms`;
        el.classList.add('is-visible');
        observer.unobserve(el);
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -32px 0px' });

    document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));
  }

  document.addEventListener('astro:page-load', initReveal);
</script>
